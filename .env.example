# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Make sure to enable the Places API for your project
VITE_GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Required for production build (and for CI). Values are in local .env (not committed).
# Add these as repository secrets for GitHub Actions: Settings → Secrets → Actions
VITE_PUBLIC_BUILDER_KEY=
VITE_MUI_X_LICENSE_KEY=
